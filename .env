# ──────────────────────────────────────────────
# VBG Guinée – Variables d'environnement
# Copiez ce fichier en .env et remplissez-le
# NE JAMAIS committer le fichier .env !
# ──────────────────────────────────────────────

# URL publique de votre projet Supabase
# Trouvez-la dans : Project Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Chaîne de connexion directe PostgreSQL Supabase
# Trouvez-la dans : Project Settings > Database > Connection string (URI)
# Format : postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:MonSuperMotDePasse@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Clé secrète Flask (générez avec : python -c "import secrets; print(secrets.token_hex(32))")
APP_SECRET_KEY=changez-moi-en-production

# Mode debug (false en production)
DEBUG=false

# Port d'écoute
PORT=8050
